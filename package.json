{
  "name": "ai-course-site",
  "version": "0.3.3",
  "description": "Course website for Principles and Applications of Artificial Intelligence",
  "license": "MIT",
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "vitepress": "^1.6.4",
    "yaml": "^2.8.2"
  },
  "scripts": {
    "docs:prepare": "node scripts/generate-course-data.mjs",
    "dev": "npm run docs:prepare && vitepress dev site",
    "build": "npm run docs:prepare && vitepress build site",
    "preview": "vitepress preview site",
    "lint": "npm-run-all --parallel --continue-on-error lint:*",
    "lint:css": "stylelint '**/*.scss'",
    "lint:formatting": "prettier --check '**/*.{scss,js,json,md,mjs,css,vue}'",
    "format": "prettier --write '**/*.{scss,js,json,md,mjs,css,vue}'",
    "test": "npm run lint"
  },
  "stylelint": {
    "ignoreFiles": [
      "site/.vitepress/theme/style.css"
    ],
    "extends": [
      "stylelint-config-standard-scss"
    ],
    "rules": {
      "alpha-value-notation": null,
      "at-rule-empty-line-before": null,
      "color-function-alias-notation": null,
      "color-function-notation": null,
      "media-feature-range-notation": "prefix",
      "no-descending-specificity": null,
      "scss/no-global-function-names": null
    }
  },
  "prettier": {
    "endOfLine": "lf",
    "semi": false,
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "es5"
  }
}
